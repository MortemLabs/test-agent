# OpenAI
OPENAI_API_KEY=your_openai_api_key

# LLM provider
# Use "openai" for the default OpenAI path
# Use "ollama" for Ollama Cloud via the official Ollama SDK
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Ollama Cloud
# Get an API key from ollama.com and use OLLAMA_HOST=https://ollama.com
# Example cloud model: gpt-oss:120b
OLLAMA_API_KEY=your_ollama_api_key
OLLAMA_HOST=https://ollama.com

# Mortem SDK - get these from your Mortem dashboard
MORTEM_API_KEY=your_mortem_api_key
MORTEM_AGENT_ID=your_mortem_agent_id
MORTEM_VERIFY_TOKEN=your_mortem_verify_token

# Solana devnet wallet
# Generate with: solana-keygen new --outfile test-wallet.json
# Fund with:     solana airdrop 1 <pubkey> --url devnet
SOLANA_PRIVATE_KEY=base58_encoded_private_key
SOLANA_RPC_URL=https://api.devnet.solana.com

# Agent behavior
# Token to analyze - try "SOL", "JUP", "BONK", "WIF"
TARGET_TOKEN=JUP

# Set to "true" to send a real devnet memo tx
# Set to "false" to skip on-chain activity
SEND_DEVNET_TX=true
